# Required
FOOTBALL_DATA_API_KEY=

# Optional - missing keys disable the related feature with a startup warning
THE_ODDS_API_KEY=

# Email (Gmail SMTP). All five must be set for email to send.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
NOTIFICATION_EMAIL_TO=

# Optional overrides
WCP_DB_PATH=./wcp.db
WCP_SERVE_PORT=8765
WCP_CLAUDE_BIN=claude
